# Database
DATABASE_URL=postgresql+asyncpg://etl:etlpassword@localhost:5432/etl_db
POSTGRES_USER=etl
POSTGRES_PASSWORD=etlpassword
POSTGRES_DB=etl_db

# Application
APP_ENV=dev
LOG_LEVEL=INFO

# JWT — generate a strong secret with: openssl rand -hex 32
JWT_SECRET_KEY=changeme-use-openssl-rand-hex-32-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API credentials for POST /api/v1/auth/token
API_USERNAME=admin
API_PASSWORD=changeme
